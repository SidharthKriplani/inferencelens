# InferenceLens — environment variables
# Copy to .env and fill in values

# Audit log path (default: ./audit_log.jsonl)
AUDIT_LOG_PATH=./audit_log.jsonl

# OpenAI (optional — only needed for live model calls, not required for demo)
OPENAI_API_KEY=sk-...

# Anthropic (optional)
ANTHROPIC_API_KEY=sk-ant-...

# Ollama endpoint (optional — for local tier)
OLLAMA_BASE_URL=http://localhost:11434

# App settings
INFERENCELENS_ENV=development
INFERENCELENS_LOG_LEVEL=INFO
